datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Usuario {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  nombre    String
  organismo String?
  direccion String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  reportes  DatosFormato[]
}

model RegistroPDF {
  id              Int      @id @default(autoincrement())
  tipoMovimiento  String   
  nombreUsuario   String   
  fechaCreacion   DateTime @default(now())
  plantilla       String   
  archivoPath     String   
  datosFormatoId  Int?
  datosFormato    DatosFormato? @relation(fields: [datosFormatoId], references: [id])
}

model DatosFormato {
  id              Int      @id @default(autoincrement())
  nombreUsuario   String
  plantilla       String
  datosJson       Json
  fechaCreacion   DateTime @default(now())
  fechaActualizacion DateTime @updatedAt
  estado          String   @default("COMPLETO") // 'COMPLETO' | 'PENDIENTE'
  usuarioId       Int?
  usuario         Usuario? @relation(fields: [usuarioId], references: [id])
  pdfsGenerados   RegistroPDF[]
}