datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model RegistroPDF {
  id              Int      @id @default(autoincrement())
  tipoMovimiento  String   
  nombreUsuario   String   
  fechaCreacion   DateTime @default(now())
  plantilla       String   
  archivoPath     String   
  datosFormatoId  Int?
  datosFormato    DatosFormato? @relation(fields: [datosFormatoId], references: [id])
}

model DatosFormato {
  id              Int      @id @default(autoincrement())
  nombreUsuario   String
  plantilla       String
  datosJson       Json
  fechaCreacion   DateTime @default(now())
  fechaActualizacion DateTime @updatedAt
  pdfsGenerados   RegistroPDF[]
}